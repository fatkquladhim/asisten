# Database (gunakan container db:5432)
DATABASE_URL=postgresql://asisten:changeme@localhost:5432/asisten
DB_PASSWORD=changeme

# Redis (gunakan sistem Redis, bukan container)
REDIS_URL=redis://localhost:6379

# LLM - Sumopod only
SUMOPOD_API_KEY=sk-...  # isi ini
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1

# Telegram (opsional tapi disarankan)
TELEGRAM_BOT_TOKEN=     # isi jika mau notifikasi
TELEGRAM_CHAT_ID=       # chat ID Anda

# Application
NODE_ENV=development
LOG_LEVEL=info
PORT=3000