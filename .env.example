# Database
DATABASE_URL=postgresql://asisten:changeme@localhost:5432/asisten
DB_PASSWORD=changeme

# Redis
REDIS_URL=redis://localhost:6379

# LLM Provider (for semantic routing & embeddings)
# Option A: OpenAI
OPENAI_API_KEY=sk-...
# Option B: Sumopod (OpenAI-compatible, used when OPENAI_API_KEY is not set)
SUMOPOD_API_KEY=sk-...
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1

# Exchange API Keys
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BYBIT_API_KEY=
BYBIT_SECRET_KEY=

# Indodax API Keys (required for trade execution)
INDODAX_API_KEY=
INDODAX_SECRET_KEY=

# Bursa API Key
BURSA_API_KEY=

# Application
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
