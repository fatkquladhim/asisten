# Database
DATABASE_URL=postgresql://asisten:changeme@localhost:5432/asisten
DB_PASSWORD=changeme

# Redis
REDIS_URL=redis://localhost:6379

# LLM Provider (Sumopod only — cheapest: qwen3.6-flash ~$0.13/1M tokens)
SUMOPOD_API_KEY=sk-...
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1

# (OPENAI_API_KEY optional for backup, not used by default)

# Exchange API Keys (Indodax primary for this system)
INDODAX_API_KEY=
INDODAX_SECRET_KEY=

# Optional other exchanges
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BYBIT_API_KEY=
BYBIT_SECRET_KEY=
BURSA_API_KEY=

# Application
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# Docker dev note: run `docker compose up -d` to start Timescale + Redis + pgvector
# Then `npm run db:migrate` or `npm run db:push`
# For paper trading baseline: `npm run dev` and let scheduler run
